{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["sandraschi"],
  "name": "filesystem-mcp",
  "description": "FastMCP 3.2+ server for file system operations, Docker container management, system monitoring, and host context.",
  "type": "mcp_server",
  "status": "production",
  "framework": "FastMCP 3.2+",
  "tools": 23,
  "transport": ["stdio", "http"],
  "keywords": [
    "filesystem",
    "docker",
    "file-operations",
    "system-monitoring",
    "mcp-server",
    "fastmcp"
  ],
  "features": {
    "file_operations": {
      "enabled": true
    },
    "docker_management": {
      "enabled": true
    },
    "system_monitoring": {
      "enabled": true
    },
    "host_context": {
      "enabled": true
    },
    "agentic_workflows": {
      "enabled": true
    }
  }
}

